rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User profile photos
    match /users/{userId}/{fileName} {
      // Only the user can upload/update their profile photo
      allow write: if request.auth != null && request.auth.uid == userId;

      // Anyone can read profile photos (for leaderboards)
      allow read: if true;
    }

    // Team logos
    match /teams/{teamId}/{fileName} {
      // Any authenticated user can upload/update team logo
      allow write: if request.auth != null;

      // Anyone can read team logos
      allow read: if true;
    }

    // Tournament logos
    match /tournaments/{tournamentId}/{fileName} {
      // Any authenticated user can upload/update tournament logo
      allow write: if request.auth != null;

      // Anyone can read tournament logos
      allow read: if true;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
