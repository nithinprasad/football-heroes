rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User profile photos
    match /users/{userId}/profile.jpg {
      // Only the user can upload/update their profile photo
      allow write: if request.auth != null && request.auth.uid == userId;

      // Anyone authenticated can read profile photos
      allow read: if request.auth != null;
    }

    // Team logos
    match /teams/{teamId}/logo.jpg {
      // Team captain or admin can upload/update team logo
      allow write: if request.auth != null;

      // Anyone authenticated can read team logos
      allow read: if request.auth != null;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
